  "substrings": [
    // Addon API groups and CRDs.
    "cert-manager.io",
    "acme.cert-manager.io",
    "policy.cert-manager.io",
    "trust.cert-manager.io",
    "traefik.io",
    "hub.traefik.io",
    "agents.x-k8s.io",
